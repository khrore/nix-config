auto-update = off
background-opacity = 0.950000
clipboard-read = allow
clipboard-write = allow
confirm-close-surface = false
font-family = JetBrainsMono Nerd Font
font-size = 16
gtk-custom-css = tab-style.css
gtk-tabs-location = top
maximize = true
mouse-hide-while-typing = true
theme = Gruvbox Dark
command = "/run/current-system/sw/bin/bash --login"

keybind = clear

keybind = super+shift+c=copy_to_clipboard
keybind = super+shift+v=paste_from_clipboard
keybind = super+shift+c=copy_to_clipboard
keybind = super+shift+v=paste_from_clipboard
keybind = super+shift+equal=increase_font_size:1
keybind = super+shift+minus=decrease_font_size:1
keybind = super+shift+zero=reset_font_size
keybind = super+shift+q=quit
keybind = super+shift+r=reload_config
keybind = super+shift+k=clear_screen
keybind = super+shift+n=new_window
keybind = super+shift+w=close_surface
keybind = super+shift+w=close_window
keybind = super+shift+t=new_tab
keybind = super+shift+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+shift+right_bracket=goto_split:next
keybind = super+shift+left_bracket=goto_split:previous

keybind = super+shift+1=goto_tab:1
keybind = super+shift+2=goto_tab:2
keybind = super+shift+3=goto_tab:3
keybind = super+shift+4=goto_tab:4
keybind = super+shift+5=goto_tab:5
keybind = super+shift+6=goto_tab:6
keybind = super+shift+7=goto_tab:7
keybind = super+shift+8=goto_tab:8
keybind = super+shift+9=goto_tab:8
