#!/bin/bash
set -e

# Overwrite all user configs with the Omarchy defaults.

if (( EUID == 0 )); then
  echo "Error: This script should not be run as root"
  exit 1
fi

echo "Resetting all Omarchy configs"
cp -R ~/.local/share/linux-desktop/config/* ~/.config/
cp ~/.local/share/linux-desktop/default/bashrc ~/.bashrc
echo '[[ -f ~/.bashrc ]] && . ~/.bashrc' | tee ~/.bash_profile >/dev/null

$(bash $HOME/.local/share/linux-desktop/install/config/theme.sh)

omarchy-refresh-limine
omarchy-refresh-plymouth
omarchy-nvim-setup
