#!/bin/bash

set -e

if (($# == 0)); then
  echo "Usage: omarchy-update-branch [master|dev]"
  exit 1
fi

branch="$1"

# Snapshot before switching branch
omarchy-snapshot create || (( $? == 127 ))

if ! git -C "$HOME/.local/share/linux-desktop" diff --quiet || ! git -C "$HOME/.local/share/linux-desktop" diff --cached --quiet; then
  stashed=true
  git -C "$HOME/.local/share/linux-desktop" stash push -u -m "Autostash before switching to $branch"
else
  stashed=false
fi

# Switch branches
git -C "$HOME/.local/share/linux-desktop" switch "$branch"

# Reapply stash if we made one
if [[ $stashed == "true" ]]; then
  if ! git -C "$HOME/.local/share/linux-desktop" stash pop; then
    echo "⚠️ Conflicts when applying stash — stash kept"
  fi
fi

# Update the system from the new branch
omarchy-update-perform
